rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAllowedEmail() {
      return request.auth.token.email != null && 
        (request.auth.token.email.matches('.*@fotus[.]com[.]br') || request.auth.token.email == 'guilhermebarbosars@gmail.com');
    }

    function isAuthenticated() {
      return request.auth != null && isAllowedEmail();
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'Admin' ||
          request.auth.token.email == "guilhermebarbosars@gmail.com"
        );
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'email', 'full_name', 'avatar_url']));
      allow delete: if isAdmin();
    }
    
    match /projetos/{projectId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tarefas/{taskId} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
    
    match /sales_metrics/{metricId} {
      allow read, write: if isAuthenticated();
    }

    match /vacations/{vacationId} {
      allow read, write: if isAuthenticated();
    }

    match /inventory_products/{id} {
      allow read, write: if isAuthenticated();
    }

    match /inventory_stocks/{id} {
      allow read, write: if isAuthenticated();
    }

    match /inventory_history/{id} {
      allow read, write: if isAuthenticated();
    }
    match /transfer_stages/{id} {
      allow read, write: if isAuthenticated();
    }

    match /transfer_cards/{id} {
      allow read, write: if isAuthenticated();
    }

    match /market_prices/{id} {
      allow read, write: if isAuthenticated();
    }
    
    match /meeting_followups/{id} {
      allow read, write: if isAuthenticated();
    }

    match /system/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
